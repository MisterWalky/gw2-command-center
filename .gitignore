# ============================================================
# GW2 Command Center
# .gitignore
# Ignore files that must not be versioned
# ============================================================

# ============================================================
# Python cache / compiled files
# ============================================================

__pycache__/
*.py[cod]
*$py.class

# ============================================================
# Python virtual environments
# ============================================================

.venv/
venv/
env/
ENV/

# ============================================================
# Environment variables (API keys, secrets)
# ============================================================

.env
.env.*

# Keep the example file versioned
!.env.example

# ============================================================
# SQLite / local databases
# ============================================================

databases/*.db
databases/*.sqlite
databases/*.sqlite3

# ============================================================
# Logs
# ============================================================

logs/*.log
logs/*.txt

# ============================================================
# Temporary files
# ============================================================

*.tmp
*.temp
*.bak
*.old

# ============================================================
# OS generated files
# ============================================================

.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# VS Code
# Keep shared project settings if needed
# ============================================================

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ============================================================
# Python build artifacts
# ============================================================

build/
dist/
*.egg-info/
.eggs/

# ============================================================
# Testing / coverage
# ============================================================

.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
# Future export folders
# ============================================================

exports/
snapshots/
temp/

# ============================================================
# Local configuration overrides
# ============================================================

config/local_*.py
