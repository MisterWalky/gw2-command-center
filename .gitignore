# ============================================================
# Projet      : GW2 Command Center
# Fichier     : .gitignore
# Rôle        : Fichiers et dossiers exclus du versioning
# Auteur      : William CROCHOT (MisterWalky)
# Référence   : https://github.com/MisterWalky/gw2-command-center
# Licence     : MIT
# ============================================================

# ------------------------------------------------------------
# DESCRIPTION
# ------------------------------------------------------------
# Ce fichier définit les fichiers et dossiers qui ne doivent
# pas être suivis par Git.
#
# Il permet notamment d'exclure :
# - les fichiers temporaires
# - les environnements locaux
# - les bases de données
# - les fichiers sensibles (.env)
# ------------------------------------------------------------



# ============================================================
# Python cache / compiled files
# ============================================================

__pycache__/
**/__pycache__/

*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# ============================================================
# Python virtual environments
# ============================================================

.venv/
venv/
env/
ENV/

# ============================================================
# Environment variables (API keys, secrets)
# ============================================================

.env
.env.*

# Keep the example file versioned
!.env.example

# ============================================================
# SQLite / local databases
# ============================================================

databases/*.db
databases/*.sqlite
databases/*.sqlite3
databases/*.db-journal
databases/*.sqlite-journal
databases/*.sqlite3-journal
databases/*.db-wal
databases/*.sqlite-wal
databases/*.sqlite3-wal
databases/*.db-shm
databases/*.sqlite-shm
databases/*.sqlite3-shm

# ============================================================
# Logs
# ============================================================

logs/*.log
logs/*.txt

# ============================================================
# Temporary files
# ============================================================

*.tmp
*.temp
*.bak
*.old

# ============================================================
# OS generated files
# ============================================================

.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# VS Code
# Keep shared project settings if needed
# ============================================================

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# ============================================================
# Python build artifacts
# ============================================================

build/
dist/
*.egg-info/
.eggs/

# ============================================================
# Testing / coverage
# ============================================================

.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
# Future export folders
# ============================================================

exports/
snapshots/
temp/

# ============================================================
# Local configuration overrides
# ============================================================

config/local_*.py
