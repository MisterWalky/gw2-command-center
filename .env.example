# ------------------------------------------------------------
# GW2 Command Center - Exemple de configuration
# ------------------------------------------------------------
# Copiez ce fichier sous le nom ".env" puis modifiez-le pour
# configurer le projet.
#
# Windows :
#   copy .env.example .env
#
# Linux / macOS :
#   cp .env.example .env
#
# Le fichier ".env" est ignoré par Git et ne sera jamais
# envoyé dans le dépôt.
# ------------------------------------------------------------



# ------------------------------------------------------------
# CLÉ API GUILD WARS 2
# ------------------------------------------------------------
# Générez votre clé API ici :
# https://account.arena.net/applications
#
# Les permissions requises dépendent des endpoints utilisés.
# ------------------------------------------------------------

GW2_API_KEY=YOUR_API_KEY_HERE



# ------------------------------------------------------------
# NOM UTILISATEUR API
# ------------------------------------------------------------
# Nom utilisé dans l’en-tête HTTP User-Agent.
#
# Cela permet à ArenaNet d’identifier l’application.
#
# Exemple de User-Agent généré par le projet :
# gw2-command-center/0.0.1-alpha (YOUR_NAME)
# ------------------------------------------------------------

GW2_API_USER=YOUR_NAME



# ------------------------------------------------------------
# LANGUE DE L'APPLICATION
# ------------------------------------------------------------
# Langue utilisée par l’interface du programme :
# - messages console
# - diagnostics
# - menus
#
# Cette langue est indépendante des langues utilisées
# par l’API.
#
# Langues supportées :
#
#   en  Anglais
#   fr  Français
#   de  Allemand
#   es  Espagnol
#   it  Italien
#   pt  Portugais
#   pl  Polonais
#   ru  Russe
#   ja  Japonais
#   ko  Coréen
#
# Si absent ou invalide :
#   valeur par défaut = en
# ------------------------------------------------------------

APP_LANG=en



# ------------------------------------------------------------
# LANGUES API
# ------------------------------------------------------------
# Langues demandées à l’API Guild Wars 2.
#
# Si absent ou vide :
#   valeur par défaut = en
#
# Langues supportées par l’API (ArenaNet)
# Référence : 2026-03
#
#   en  Anglais
#   fr  Français
#   de  Allemand
#   es  Espagnol
#
# Valeur spéciale :
#
#   all
#
# Exemples avec une seule langue :
#
#   GW2_API_LANGS=en
#   GW2_API_LANGS=fr
#
# Exemples avec plusieurs langues :
#
#   GW2_API_LANGS=fr,en
#   GW2_API_LANGS=fr,en,de
#
# Toutes les langues supportées :
#
#   GW2_API_LANGS=all
#
# Remarques :
#
# - l’ordre est important
# - les doublons sont ignorés
# - les langues non supportées sont ignorées
# - utiliser des virgules sans espaces
#
# Documentation officielle :
# https://wiki.guildwars2.com/wiki/API:Main
# ------------------------------------------------------------

GW2_API_LANGS=en
