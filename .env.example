# ============================================================
# Projet      : GW2 Command Center
# Fichier     : .env.example
# Rôle        : Exemple de configuration utilisateur
# Auteur      : William CROCHOT (MisterWalky)
# Référence   : https://github.com/MisterWalky/gw2-command-center
# Licence     : MIT
# ============================================================

# ------------------------------------------------------------
# DESCRIPTION
# ------------------------------------------------------------
# Ce fichier sert de modèle pour configurer l'application.
#
# Il doit être copié sous le nom ".env" puis modifié localement.
#
# Le fichier ".env" contient des données sensibles et est
# automatiquement ignoré par Git.
# ------------------------------------------------------------

# ------------------------------------------------------------
# UTILISATION
# ------------------------------------------------------------
# Windows :
#   copy .env.example .env
#
# Linux / macOS :
#   cp .env.example .env
# ------------------------------------------------------------



# ------------------------------------------------------------
# CLÉ API GUILD WARS 2
# ------------------------------------------------------------
# ⚠️ Ne partagez jamais votre clé API publiquement
#
# Générez votre clé API ici :
# Lien :
# https://account.arena.net/applications
#
# Les permissions requises dépendent des endpoints utilisés.
# ------------------------------------------------------------

GW2_API_KEY=YOUR_API_KEY_HERE



# ------------------------------------------------------------
# NOM UTILISATEUR API
# ------------------------------------------------------------
# Nom utilisé dans l’en-tête HTTP User-Agent.
#
# Cela permet à ArenaNet d’identifier l’application.
#
# Exemple de User-Agent généré :
# gw2-command-center/0.0.1-alpha (your-name)
# ------------------------------------------------------------

GW2_API_USER=your-name



# ------------------------------------------------------------
# LANGUE DE L'APPLICATION
# ------------------------------------------------------------
# Langue utilisée par l’interface du programme :
# - messages console
# - diagnostics
# - menus
#
# Cette langue est indépendante des langues utilisées
# par l’API.
#
# Langues supportées :
#
#   en  Anglais
#   fr  Français
#   de  Allemand
#   es  Espagnol
#   it  Italien
#   pt  Portugais
#   pl  Polonais
#   ru  Russe
#   ja  Japonais
#   ko  Coréen
#
# Si absent ou invalide :
#   valeur par défaut = en
# ------------------------------------------------------------

APP_LANG=en



# ------------------------------------------------------------
# LANGUES API
# ------------------------------------------------------------
# Langues demandées à l’API Guild Wars 2.
#
# Si absent ou vide :
#   valeur par défaut = en
#
# Langues supportées par l’API (ArenaNet)
# Référence : 2026-03
#
#   en  Anglais
#   fr  Français
#   de  Allemand
#   es  Espagnol
#
# Valeur spéciale :
#
#   all
#
# Exemples avec une seule langue :
#
#   GW2_API_LANGS=en
#   GW2_API_LANGS=fr
#
# Exemples avec plusieurs langues :
#
#   GW2_API_LANGS=fr,en
#   GW2_API_LANGS=fr,en,de
#
# Toutes les langues supportées :
#
#   GW2_API_LANGS=all
#
# Remarques :
#
# - l’ordre est important
# - les doublons sont ignorés
# - les langues non supportées sont ignorées
# - utiliser des virgules sans espaces
#
# Documentation officielle :
# Lien :
# https://wiki.guildwars2.com/wiki/API:Main
# ------------------------------------------------------------

GW2_API_LANGS=en
