# ============================================================
# GW2 Command Center
# Example environment configuration
# Copy this file to ".env" and replace the values below

# ============================================================
# Guild Wars 2 API key
# Generate your key here:
# https://account.arena.net/applications

GW2_API_KEY=YOUR_API_KEY_HERE

# Optional identifier for API usage
# Can be used in logs, analytics or exports
GW2_API_USER=YOUR_NAME
